# Copy to backend/.env and fill in. Never commit the real .env.
# Free key from https://openrouteservice.org/dev/#/signup
GEOAPIFY_API_KEY=

# Sent as the User-Agent to Nominatim. Their usage policy requires a descriptive
# agent identifying the application; requests without one are blocked.
NOMINATIM_USER_AGENT=eld-trip-planner/1.0 (contact@example.com)
